# SecureData Archive local runtime profile.
# Copy to .env.local or run ./scripts/setup.sh to generate strong local secrets.

SECUREDATA_RUN_DIR=/home/ruslan/.securedata-run
SECUREDATA_IPFS_ROOT=/home/ruslan/.securedata-ipfs

FLASK_SECRET=replace-with-64-plus-random-chars
INVITE_SIGNING_KEY=replace-with-64-plus-random-chars
SECURITY_AGENT_TOKEN=replace-with-64-plus-random-chars

FABRIC_PATH=/home/ruslan/fabric-dev/fabric-samples/test-network
CHAINCODE_PATH=/home/ruslan/working/chaincode

HOST=127.0.0.1
PORT=5500
BACKEND_PORT=5500
STATIC_HOST=127.0.0.1
STATIC_PORT=8000
AI_PORT=8100
AGENT_PORT=8090

WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:8000
WEB_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

AI_SERVICE_URL=http://127.0.0.1:8100
AI_SERVICE_AUTOSTART=0
AUTO_SUGGEST=1
AUTO_SUGGEST_MIN_CONF=80.0

AGENT_AUTOSTART=1
AGENT_IDENTITIES=SecurityService,MLService
AGENT_DISABLE_AUTH=0

IPFS_NODE_URLS=http://127.0.0.1:5011,http://127.0.0.1:5012
IPFS_MIN_REPLICAS=2
IPFS_TARGET_REPLICAS=2
IPFS_STRICT_CID=1
