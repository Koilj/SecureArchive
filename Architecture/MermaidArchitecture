        FabricProxy["/fabric/eval + /fabric/submit<br/>offline signing state machine"]
        DownloadAPI["/download/asset/{assetId}<br/>recent key-fetch grant required"]
        IPFSMon["IPFS replication monitor<br/>status cache + repair loop"]
        ServiceRelay["Service relay<br/>SecurityService / MLService agent calls"]
        ProcessMgr["Autostart supervisor<br/>agent-go + optional AI service"]
        RuntimeSecrets["Runtime secrets<br/>FLASK_SECRET, INVITE_SIGNING_KEY,<br/>SECURITY_AGENT_TOKEN"]
    end

    subgraph AI["AI service on :8100"]
        AISvc["FastAPI /predict /predict/batch"]
        SciBERT["SciBERT multilabel model<br/>tokenizer, encoder, thresholds, categories.json"]
