    ShareReady["Asset can be shared"]

    Requester["Requester browses public asset"]
    RequestAccess["RequestAccessWithReason"]
    AccessDecision{"Chaincode policy result"}
    Denied["DENIED<br/>ABAC, blocked user, or asset scan"]
    Pending["PENDING owner review"]
    OwnerGrant["Owner decrypts own key locally<br/>wraps content key for requester"]
    GrantAccess["GrantAccess stores requester key envelope"]
    AccessGranted["Requester has access<br/>encrypted key envelope stored"]

    DownloadStart["Authorized user downloads"]
    KeyFetch["RequestMyEncryptedKey transaction"]
    RecentGrant{"Backend session has recent key-fetch grant?"}
    FetchEncrypted["Backend fetches encrypted blob from IPFS"]
    LocalDecrypt["Browser unwraps content key,<br/>decrypts payload, verifies fileHash"]
    LogDownload["LogDownload ledger audit"]

    RiskEvents["Risk-relevant chaincode events<br/>ACCESS_DENIED, ASSET_KEY_FETCHED, ASSET_DOWNLOADED"]
    RiskBlock{"Risk threshold crossed?"}
    AutoBlock["Risk engine submits BlockUserForSeconds"]
    SecurityReview["SecurityService reviews audit, downloads,<br/>evidence trail, blocked users"]

    Start --> Health --> BootstrapNeeded
    BootstrapNeeded -- yes --> BootstrapTicket --> SecActivate --> SecSession
    BootstrapNeeded -- no --> SecSession
    SecSession --> CreateUsers --> UserActivate
    SecSession --> Workspace
    UserActivate --> RecoveryGate
    RecoveryGate -- no --> CreateRecovery --> Workspace
    RecoveryGate -- yes --> Workspace

    Workspace --> Upload --> Encrypt --> Sanitize
    Sanitize -->|reject| UploadRejected["Reject request with DISP reasons"]
    Sanitize -->|allow or allow_with_review| Predict --> StoreIPFS --> CommitAsset --> SuggestDecision
    SuggestDecision -- yes --> StoreSuggestion --> NeedsReview
    SuggestDecision -- no --> NeedsReview
    NeedsReview --> Approve --> ShareReady

    Workspace --> Requester --> RequestAccess --> AccessDecision
    AccessDecision -- denied --> Denied --> RiskEvents
    AccessDecision -- pending --> Pending --> OwnerGrant --> GrantAccess --> AccessGranted

    ShareReady --> DownloadStart --> KeyFetch --> RecentGrant
    AccessGranted --> DownloadStart
    KeyFetch --> RiskEvents
    RecentGrant -- no --> DownloadDenied["403: use /download/asset only after key fetch"]
    RecentGrant -- yes --> FetchEncrypted --> LocalDecrypt --> LogDownload --> RiskEvents

    RiskEvents --> RiskBlock
    RiskBlock -- yes --> AutoBlock --> SecurityReview
    RiskBlock -- no --> SecurityReview
    Workspace --> SecurityReview
```

